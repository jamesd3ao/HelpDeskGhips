# =========================
# 🔐 CREDENCIALES DE CORREO
# =========================
# Servidor SMTP (Office 365 típico)
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USE_TLS=true

# Usuario/contraseña SMTP (NO subas este archivo a Git)
MAIL_USERNAME=soportetic.sedeprincipal@almamater.hospital
MAIL_PASSWORD=SoporteT1ts

# Remitente por defecto (si no lo pones, se usará MAIL_USERNAME)
MAIL_DEFAULT_SENDER=soportetic.sedeprincipal@almamater.hospital

# Correo de Logística (destinatario de notificaciones con PDF)
LOGISTICA_EMAIL=danni.mejiac@almamater.hospital


# =========================
# 🔧 CONFIG DE LA APLICACIÓN
# =========================
# Clave de sesión Flask (cámbiala por algo largo/aleatorio en prod)
SECRET_KEY=Proyecto_mesa_ayuda_ticket
SESSION_COOKIE_NAME=mesa_ayuda_cookie

# Puerto donde correr la app (opcional)
PORT=5006

# Ruta del logo que usa el PDF (ya está en app.config como LOGO_PATH='static/img/logo.png')
# No hace falta definirla en .env salvo que quieras cambiar la ruta.


# =========================
